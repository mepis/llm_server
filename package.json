{
  "name": "llm_server",
  "version": "1.0.0",
  "description": "Local LLM management system with llama.cpp and Vue.js frontend",
  "main": "server/index.js",
  "type": "module",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "node server/index.js",
    "start": "NODE_ENV=production node server/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "npm run test -- --watch",
    "test:coverage": "npm run test -- --coverage",
    "build:frontend": "cd web && npm run build",
    "dev:frontend": "cd web && npm run dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mepis/llm_server.git"
  },
  "keywords": [
    "llama.cpp",
    "llm",
    "local",
    "ai",
    "model-management",
    "vue"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mepis/llm_server/issues"
  },
  "homepage": "https://github.com/mepis/llm_server#readme",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "sql.js": "^1.8.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.3",
    "c8": "^10.1.3",
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  }
}
