{
  "name": "llm_server",
  "version": "1.0.0",
  "description": "Comprehensive Llama.cpp-based chat system with RBAC, RAG, and Matrix integration",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "worker": "node src/workers/worker.js",
    "seed-admin": "node src/scripts/createAdmin.js",
    "seed-config": "node src/scripts/seedConfig.js",
    "test": "node src/tests/testAll.js",
    "qdrant:install": "bash scripts/install-qdrant.sh",
    "qdrant:start": "bash scripts/start-qdrant.sh",
    "qdrant:stop": "bash scripts/stop-qdrant.sh",
    "qdrant:status": "bash scripts/qdrant-status.sh"
  },
  "dependencies": {
    "@qdrant/js-client-grpc": "^1.17.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "fastestsmallesttextencoderdecoder": "^1.0.22",
    "form-data": "^4.0.0",
    "glob": "^10.4.0",
    "gray-matter": "^4.0.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mammoth": "^1.12.0",
    "mariadb": "^3.4.0",
    "matrix-js-sdk": "^39.2.0",
    "multer": "^2.0.0",
    "mysql2": "^3.22.2",
    "node-argon2": "^1.0.0",
    "pdf-parse": "^1.1.4",
    "piscina": "^4.7.0",
    "uuid": "^10.0.0",
    "winston": "^3.17.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "engines": {
    "node": ">=24.12.0"
  }
}
