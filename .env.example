# LLM Server Environment Configuration (example)
# Copy to '.env' and fill with real values in your environment.

# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/llm_server
MONGODB_OPTIONS=socketTimeoutMS=30000,connectTimeoutMS=10000

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:5173

# Llama.cpp server
LLAMA_SERVER_URL=http://localhost:11434
LLAMA_TIMEOUT=30000
TTS_SPEAKER_FILE=/path/to/tts_speaker.json

# Chatterbox TTS Configuration
CHATTERBOX_GRPC_HOST=localhost
CHATTERBOX_GRPC_PORT=50051
CHATTERBOX_SPEAKER_FILE=/path/to/speaker_reference.wav
CHATTERBOX_TEMPERATURE=0.8
CHATTERBOX_TOP_P=0.95
CHATTERBOX_TOP_K=1000

# Matrix (optional)
MATRIX_HOMESERVER=https://matrix.org
MATRIX_ACCESS_TOKEN=null
MATRIX_USER_ID=null

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# Session
SESSION_TIMEOUT=86400000

# File uploads
MAX_FILE_SIZE=10485760

# Debug
DEBUG_MENU_ENABLED=false
