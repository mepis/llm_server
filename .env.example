# ============================================
# LLM Server Environment Configuration
# ============================================
# Copy this file to .env and update values for your environment
# Required variables must be set for the server to start
# ============================================

# --------------------------------------------
# Server Configuration
# --------------------------------------------
PORT=3000
NODE_ENV=development

# --------------------------------------------
# Database Configuration (REQUIRED)
# --------------------------------------------
MONGODB_URI=mongodb://localhost:27017/llm_server
MONGODB_OPTIONS=socketTimeoutMS=30000,connectTimeoutMS=10000

# --------------------------------------------
# Authentication Configuration (REQUIRED)
# --------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# --------------------------------------------
# Frontend Configuration
# --------------------------------------------
FRONTEND_URL=http://localhost:5173

# --------------------------------------------
# Llama.cpp Server Configuration
# --------------------------------------------
LLAMA_SERVER_URL=http://localhost:8082
LLAMA_TIMEOUT=30000

# --------------------------------------------
# Matrix Integration (Optional)
# --------------------------------------------
MATRIX_HOMESERVER=https://matrix.org
MATRIX_ACCESS_TOKEN=null
MATRIX_USER_ID=null

# --------------------------------------------
# Logging Configuration
# --------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=combined

# --------------------------------------------
# Session Configuration
# --------------------------------------------
SESSION_TIMEOUT=86400000

# --------------------------------------------
# File Upload Configuration
# --------------------------------------------
MAX_FILE_SIZE=10485760

# --------------------------------------------
# Debug Features
# --------------------------------------------
DEBUG_MENU_ENABLED=true
